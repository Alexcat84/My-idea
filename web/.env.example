# Fase 3.0. Copiar a .env.local para desarrollo; en Vercel, configurar
# estas mismas variables en Project Settings > Environment Variables.
# NUNCA commitear .env.local ni valores reales (ya gitignored).

# Mismo proyecto Supabase que ya usa el CLI (engine/.env: SUPABASE_URL).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, jamas exponer al cliente (bypassa RLS).
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Mismo valor que engine/.env: ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=

# Server-only. Nuevo para Fase 3.0: brujula semantica (Voyage AI en vez de
# sentence-transformers, que es Python y no viaja a la web).
VOYAGE_API_KEY=

# Server-only. Rate limiting en beta (patron Upstash del proyecto I Ching).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
