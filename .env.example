# ==================================================================
# My Idea — plantilla del .env de la raíz (copiar a .env y llenar).
# El .env real JAMÁS va a git. Estructura documentada al 2026-07-19.
# ==================================================================

# --- Motor / IA ---------------------------------------------------
# También en Vercel (production + preview).
ANTHROPIC_API_KEY=
# Brújula semántica de la web (Voyage AI). También en Vercel.
VOYAGE_API_KEY=

# --- Supabase -----------------------------------------------------
# También en Vercel (allá además como NEXT_PUBLIC_SUPABASE_URL y
# NEXT_PUBLIC_SUPABASE_ANON_KEY para el cliente del navegador).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only: bypassa RLS. Jamás exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate limiting (Upstash, patrón del I Ching) ------------------
# También en Vercel (production + preview).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# ETAPA 2 (beta): "usuario" = límite diario por identidad real.
RATE_LIMIT_POR=usuario

# --- Login con Google — registro del fundador ---------------------
# El código NUNCA las lee: viven en Google Cloud y se pegan en
# Supabase → Authentication → Providers → Google. Registro/respaldo.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_CLOUD_PROJECT_ID=

# --- Resend (correos del código de acceso) ------------------------
# El código no la lee: vive en Supabase (Auth → SMTP). Registro.
RESEND_API_KEY=

# --- Arneses de desarrollo (vuelos y gates) -----------------------
DEV_USER_ID=
VUELO_DEV_PASSWORD=

# --- Tooling ------------------------------------------------------
# CLI/API de Vercel (URLs de preview, variables de entorno, deploys).
VERCEL_TOKEN=
